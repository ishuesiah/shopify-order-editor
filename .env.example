# Shopify Store Configuration
# Your store name (the part before .myshopify.com)
SHOPIFY_STORE=hemlock-oak

# Admin API Access Token
# Get this from: Shopify Admin > Settings > Apps and sales channels > Develop apps
# Create a new app with these scopes: write_orders, read_orders, read_products
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your store's domain for CORS
SHOP_DOMAIN=hemlock-oak.myshopify.com

# Server port (optional, defaults to 3000)
PORT=3000
